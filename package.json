{
  "name": "demo-threejs-game",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "screenshot": "node scripts/screenshot.mjs",
    "create-pr": "node scripts/create-pr.mjs",
    "server": "cd server && uvicorn main:app --reload --port 8000",
    "sync": "git checkout main && git fetch --prune --all && git pull && git branch | grep -v \"main\" | xargs git branch -d"
  },
  "dependencies": {
    "three": "^0.171.0"
  },
  "devDependencies": {
    "@types/three": "^0.171.0",
    "playwright": "^1.58.2",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "vitest": "^3.2.4"
  }
}
